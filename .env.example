# PostgreSQL (used by docker-compose for postgres container)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ──────────────────────────────────────────────
# Below values go in .env.runtime (loaded by app via env_file)
# ──────────────────────────────────────────────

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=<64 hex chars>

# JSON map: {"bearer-token": "user-id"}
# Generate tokens with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# API_KEYS={"your-token-here":"user-1"}

# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# PORT_RANGE_START=19000
# PORT_RANGE_END=19999
# MAX_INSTANCES_PER_USER=20
