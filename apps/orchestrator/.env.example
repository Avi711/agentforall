# ── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/agentforall
# 64 hex chars (256-bit). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Auth ────────────────────────────────────────────────────────────────────
# JSON object mapping API key → user id. Used by CLI / direct integrators who
# call the orchestrator as a single user.
#   Example: {"aaaa...32chars...":"user-cli"}
API_KEYS={}

# Comma-separated list of trusted service tokens. These let a server caller
# (e.g. the Next.js dashboard) impersonate any user via the X-Act-As-User
# header. Standard PaaS impersonation pattern; each token must be 32+ chars.
# Generate with: openssl rand -hex 32
SERVICE_TOKENS=

# ── HTTP server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000
NODE_ENV=development
TRUST_PROXY=true

# ── Docker ──────────────────────────────────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/avi711/openclaw-browser:latest
# Leave DOCKER_HOST / DOCKER_SOCKET_PATH unset to use the default socket.
# DOCKER_HOST=
# DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_NETWORK=tenant-net

# Host-port range allocated to tenant gateway containers. Bound to 127.0.0.1.
PORT_RANGE_START=19000
PORT_RANGE_END=19999

# ── Health monitoring ───────────────────────────────────────────────────────
HEALTH_POLL_INTERVAL_MS=15000
HEALTH_DEGRADED_THRESHOLD=3
HEALTH_UNHEALTHY_THRESHOLD=5
HEALTH_REQUEST_TIMEOUT_MS=5000

# ── Lifecycle ───────────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=10000
RECONCILE_ON_STARTUP=true
RECONCILE_INTERVAL_MS=60000
MAX_PROVISION_RETRIES=3
MAX_INSTANCES_PER_USER=1

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── WhatsApp pairing sidecar ────────────────────────────────────────────────
PAIRING_IMAGE=ghcr.io/agentforall/whatsapp-pairing:latest
PAIRING_PORT=18790
PAIRING_IDLE_TIMEOUT_MS=600000
PAIRING_REQUEST_TIMEOUT_MS=5000
PAIRING_STALE_THRESHOLD_MS=900000
PAIRING_LOG_LEVEL=info

# URL the pairing sidecar uses to call back to this orchestrator. Inside the
# tenant-net docker network, refer to the orchestrator by container
# name (e.g. http://agent-forall:3000).
ORCHESTRATOR_INTERNAL_URL=http://orchestrator:3000

# Default LLM provider — applied when a create-bot request omits `provider`.
DEFAULT_PROVIDER_NAME=anthropic
DEFAULT_PROVIDER_API_KEY=
DEFAULT_PROVIDER_MODEL=claude-opus-4-7
