DATABASE_URL="postgresql://user:password@localhost:5432/agentforall"
NEXT_PUBLIC_META_PIXEL_ID=803144279101703
ADMIN_PASSWORD=change-me-to-a-strong-password

# Meta Conversions API — server-side event forwarding for the Pixel.
# Generate in Events Manager → Data Sources → <Pixel> → Settings → "Generate access token".
# Leave unset in dev if you don't want events sent; the Pixel still works client-side.
META_CAPI_ACCESS_TOKEN=
# Optional: when set, events show up only in Events Manager → Test Events
# under this code. Never set in production.
META_CAPI_TEST_EVENT_CODE=
# Optional: pin a specific Graph API version (defaults to v22.0).
META_CAPI_API_VERSION=

# ── Better Auth ─────────────────────────────────────────────────────────────
# Random 32+ byte secret used to sign session cookies.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL the app is reachable at. Must match the Google OAuth redirect URI
# (see below) host: ${BETTER_AUTH_URL}/api/auth/callback/google
# Local dev: http://localhost:3000   Prod: https://agentforall.co.il
BETTER_AUTH_URL=http://localhost:3000

# Optional: used by the client so it knows the origin for API calls.
# In single-host deployments this equals BETTER_AUTH_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth 2.0 client credentials.
# Create in: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Transactional email (magic-link sign-in) ────────────────────────────────
# Resend API key. Leave empty in dev to log magic links to the server console
# instead of emailing them.
RESEND_API_KEY=
# From address for auth emails. Must be a verified sender on your Resend account.
AUTH_EMAIL_FROM=login@agentforall.co.il

# ── Orchestrator (server-side calls from Next.js) ───────────────────────────
# Base URL of the agent orchestrator. In prod this is typically
# https://orchestrator.agentforall.co.il (behind Caddy + TLS). In local dev
# the orchestrator runs on a local Docker daemon on a different port.
ORCHESTRATOR_BASE_URL=http://localhost:3001

# Trusted service token for server-to-server auth. Must match one of the
# tokens listed in the orchestrator's SERVICE_TOKENS env var. 32+ chars.
# Generate with: openssl rand -hex 32
ORCHESTRATOR_SERVICE_TOKEN=

# Default LLM provider the dashboard injects when creating bots.
ORCHESTRATOR_PROVIDER=anthropic
ORCHESTRATOR_PROVIDER_API_KEY=
ORCHESTRATOR_PROVIDER_MODEL=claude-opus-4-7

# ── eSIM partner ────────────────────────────────────────────────────────────
# Optional affiliate link shown in the pairing flow. Leave blank to hide the card.
NEXT_PUBLIC_ESIM_PARTNER_URL=
