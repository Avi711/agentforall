DATABASE_URL="postgresql://user:password@localhost:5432/agentforall"
NEXT_PUBLIC_META_PIXEL_ID=803144279101703
ADMIN_PASSWORD=change-me-to-a-strong-password

# Meta Conversions API — server-side event forwarding for the Pixel.
# Generate in Events Manager → Data Sources → <Pixel> → Settings → "Generate access token".
# Leave unset in dev if you don't want events sent; the Pixel still works client-side.
META_CAPI_ACCESS_TOKEN=
# Optional: when set, events show up only in Events Manager → Test Events
# under this code. Never set in production.
META_CAPI_TEST_EVENT_CODE=
# Optional: pin a specific Graph API version (defaults to v22.0).
META_CAPI_API_VERSION=
